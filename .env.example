# Play AI Example Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# Provider Selection
# ===========================================
# Options: openai | anthropic | gemini | ollama
PLAY_AI_PROVIDER=openai

# Enable debug logging
PLAY_AI_DEBUG=true

# ===========================================
# OpenAI Configuration
# ===========================================
OPENAI_API_KEY=sk-...

# ===========================================
# Anthropic Claude Configuration
# ===========================================
ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# Google Gemini Configuration
# ===========================================
GEMINI_API_KEY=...

# ===========================================
# Ollama Configuration (Local)
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ===========================================
# Snapshot Strategy (Optional)
# ===========================================
# Options: full | targeted | auto
PLAY_AI_SNAPSHOT_STRATEGY=full

# ===========================================
# Code Generation (Optional)
# ===========================================
# Enable to generate standalone Playwright tests
PLAY_AI_GENERATE_CODE=false
# Output directory for generated test files
PLAY_AI_CODE_OUTPUT_DIR=./generated

# ===========================================
# Auto-Healing (Optional)
# ===========================================
# Enable auto-healing during test runs
PLAY_AI_HEALING=false
# Enable healing debug output
PLAY_AI_HEALING_DEBUG=false
